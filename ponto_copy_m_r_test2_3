import numpy as np
import matplotlib.pyplot as plt
import matplotlib.dates as mdates
import pandas as pd
from scipy.stats import linregress
import h5py

# -------------------------------------------------------------
# 1. Função do filtro de 3 passadas (equivalente ao MATLAB)
# -------------------------------------------------------------
def filtro_tres_passos(nimar):
    n = len(nimar)

    xx1 = nimar.copy()
    xx2 = nimar.copy()
    xx3 = nimar.copy()

    # 1ª passada (24 pontos)
    for k in range(12, n-12):
        xx1[k] = np.mean(nimar[k-12:k+12])

    # 2ª passada (25 pontos)
    for k in range(12, n-12):
        xx2[k] = np.mean(xx1[k-12:k+13])

    # 3ª passada (25 pontos)
    for k in range(12, n-12):
        xx3[k] = np.mean(xx2[k-12:k+13])

    # Bordas
    xx3[:12] = xx3[12]
    xx3[n-12:] = xx3[n-13]

    return xx3

# -------------------------------------------------------------
# 2. Carregar dados
# -------------------------------------------------------------
with h5py.File('C:/Users/lima-/Downloads/python/MA/adt_11y_sel.mat', 'r') as f:
    lon = np.array(f['lon_sel']).squeeze()
    lat = np.array(f['lat_sel']).squeeze()
    adt = np.array(f['topog_sel'])

if adt.shape[-1] != 11322:
    adt = np.transpose(adt)

nutime = adt.shape[2]
datas = pd.date_range(start='1993-01-01', periods=nutime, freq='D')

# -------------------------------------------------------------
# 3. Lista dos pontos
# -------------------------------------------------------------
pontos = [
    (-45.950745, -1.025438),
    (-45.579382,  -1.156578), 
    (-45.254512, -1.485709), 
    (-44.612493, -1.678496),
    (-44.216131, -2.334498),
    (-43.484629, -2.302975),
    (-42.735227, -2.502361),
    (-42.199938, -2.639296)
]

lonmin, lonmax = lon.min(), lon.max()
latmin, latmax = lat.min(), lat.max()
dlon = lon[1] - lon[0]
dlat = lat[1] - lat[0]

# -------------------------------------------------------------
# 4. Preparar estruturas
# -------------------------------------------------------------
slopes = []
altim_all = []
filtered_all = []

fig, axs = plt.subplots(2, 4, figsize=(24, 14))
axs = axs.flatten()

# -------------------------------------------------------------
# 5. Loop principal
# -------------------------------------------------------------
for i, (lonsel, latsel) in enumerate(pontos):

    indlonsel = int(np.floor((lonsel - lonmin) / dlon))
    indlatsel = int(np.floor((latsel - latmin) / dlat))

    altim1d = adt[indlonsel, indlatsel, :].squeeze()
    altim_all.append(altim1d)

    # ✅ Aplicar filtro
    altim_filt = filtro_tres_passos(altim1d)
    filtered_all.append(altim_filt)

    dias = np.arange(nutime)

    # ✅ Ajuste linear
    slope, intercept, r_value, p_value, std_err = linregress(dias, altim_filt)
    slopes.append(slope)
    altim_pol = intercept + slope * dias

    R2 = r_value**2

    ax = axs[i]

    # ✅ Plotar série filtrada
    ax.plot(datas, altim_filt, color='black', linewidth=2,
            label="Filtrado (3-pass)")
    
    # ✅ Plotar linha de tendência
    ax.plot(datas, altim_pol, color='red', linestyle='--', linewidth=2,
            label=f"Tendência (R² = {R2:.3f})")    

    # Layout
    ax.grid(alpha=0.3)
    ax.set_ylim([0.2, 1.2])
    ax.set_xlim([datas[0], datas[-1]])
    ax.xaxis.set_major_locator(mdates.YearLocator(5))
    ax.xaxis.set_major_formatter(mdates.DateFormatter('%Y'))
    ax.tick_params(axis='x', rotation=45, labelsize=10)
    ax.tick_params(axis='y', labelsize=10)
    ax.set_xlabel('Ano', fontsize=12, fontweight='bold')
    ax.set_ylabel('TDA (m)', fontsize=12, fontweight='bold')

    titulo = f'MA-{i+1}: {lonsel:.2f} W, {latsel:.2f} S'
    ax.set_title(titulo, fontsize=13, fontweight='bold', pad=12)

    # ✅ Texto interno
    ax.text(
        datas[int(nutime*0.70)],
        altim1d.min() + 0.05,
        #f"Tend: {slope*365*1000:.3f} mm/ano \np value = {p_value:.2f}",
        f"Tend: {slope*365*1000:.3f} mm/ano",
        fontsize=10,
        color='red',
        fontweight='bold'
    )

    ax.legend(fontsize=10, loc='upper left')

# -------------------------------------------------------------
# 6. Estatísticas gerais
# -------------------------------------------------------------
altim_all = np.array(altim_all)
filtered_all = np.array(filtered_all)
slopes = np.array(slopes)

# ✅ Média filtrada
altim_mean = np.mean(filtered_all, axis=0)

# ✅ Tendência da média filtrada
slope_mean, intercept_mean, r_mean, p_mean, slope_mean_stderr = linregress(dias, altim_mean)

# ✅ Imprimir no terminal
print("\n===== RESULTADOS GERAIS =====")
print(f"Média dos slopes individuais: {np.mean(slopes)*365*1000:.3f} mm/ano")
print(f"Desvio padrão dos slopes individuais: {np.std(slopes)*365*1000:.3f} mm/ano")

print(f"\nSlope da série média filtrada: {slope_mean*365*1000:.3f} mm/ano")
print(f"Erro padrão do slope da média: {slope_mean_stderr*365*1000:.3f} mm/ano")
print("==============================\n")

# -------------------------------------------------------------
# 7. Finalizar figura
# -------------------------------------------------------------
fig.suptitle("Séries temporais de TDA filtrada - 1993 a 2023 (8 pontos)",
             fontsize=18, fontweight='bold')

plt.tight_layout(rect=[0, 0, 1, 0.96])
plt.savefig('adt_serie_temporal_8_pontos_filtrada.png', dpi=300)
plt.show()